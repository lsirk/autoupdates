#!/usr/bin/env bash
#
# autoupdates — manage automatic system updates on Ubuntu
#
# Usage:
#   sudo autoupdates enable [ -f | --force ]   enable apt timers, optionally trigger now
#   sudo autoupdates disable                   disable all timers and hold snap indefinitely
#   autoupdates status                         show current state
#
# Manages:
#   apt-daily.timer, apt-daily-upgrade.timer, unattended-upgrades.service,
#   update-notifier-download.timer, fwupd-refresh.timer
#
# Requires: systemd, Ubuntu 20.04+

set -uo pipefail

APT_CFG="/etc/apt/apt.conf.d/20auto-upgrades"
SNAP_HOLD_DATE="2999-12-31T23:59:59Z"

APT_TIMERS=(
    apt-daily.timer
    apt-daily-upgrade.timer
    update-notifier-download.timer
    fwupd-refresh.timer
)

ok()   { echo "[ OK ] $*"; }
info() { echo "[INFO] $*"; }
err()  { echo "[FAIL] $*"; }

require_root() {
    if [[ $EUID -ne 0 ]]; then
        err "Run as root (use sudo)"
        exit 1
    fi
}

usage() {
    cat <<EOF

autoupdates — manage automatic system updates

Usage:
  sudo autoupdates enable | on [options]  enable all automatic updates
  sudo autoupdates disable | off          disable all automatic updates
  autoupdates status                      show current state

Options:
  -f, --force                             instantly trigger updates when enabling

Examples:
  sudo autoupdates enable                 enable updates (standard schedule)
  sudo autoupdates enable --force         enable updates and run them right now
  sudo autoupdates disable                disable before system maintenance
  autoupdates status                      check current state

EOF
    exit 1
}

enable_updates() {
    local force_trigger=0
    
    # Strict validation of the second argument if present
    if [[ -n "${1:-}" ]]; then
        if [[ "$1" == "-f" || "$1" == "--force" ]]; then
            force_trigger=1
        else
            err "Unknown option: '$1'"
            usage
        fi
    fi

    info "Enabling system automatic updates"

    local failed=0
    for unit in "${APT_TIMERS[@]}"; do
        systemctl enable --now "$unit" >/dev/null 2>&1 || { err "Failed to enable $unit"; failed=1; }
    done
    
    # Enable and start the unattended-upgrades service
    systemctl enable --now unattended-upgrades.service >/dev/null 2>&1 || { err "Failed to enable unattended-upgrades.service"; failed=1; }

    cat > "$APT_CFG" <<EOF
APT::Periodic::Update-Package-Lists "1";
APT::Periodic::Download-Upgradeable-Packages "1";
APT::Periodic::Unattended-Upgrade "1";
EOF

    if command -v snap >/dev/null 2>&1; then
        info "Restoring Snap updates to automatic schedule"
        snap unset system refresh.hold  >/dev/null 2>&1 || true
        snap unset system refresh.timer >/dev/null 2>&1 || true
    fi

    if [[ $failed -eq 0 ]]; then
        ok "System updates ENABLED"
        
        # Instantly run synchronous updates if the force flag is present
        if [[ $force_trigger -eq 1 ]]; then
            info "Force flag detected. Running APT index update..."
            apt-get update -y >/dev/null 2>&1 || true
            
            info "Running unattended-upgrades in foreground..."
            unattended-upgrade -v || true

            # Forced Snap update block
            if command -v snap >/dev/null 2>&1; then
                info "Running Snap refresh..."
                snap refresh || true
            fi
            
            ok "Forced update process completed"
        else
            info "Updates will run normally according to the systemd schedule."
        fi
    else
        err "System updates enabled with errors"
        return 1
    fi
}

disable_updates() {
    # Ensure no extra arguments are passed to disable
    if [[ -n "${1:-}" ]]; then
        err "Disable command does not accept extra options: '$1'"
        usage
    fi

    info "Disabling system automatic updates"

    local failed=0
    for unit in "${APT_TIMERS[@]}"; do
        systemctl disable --now "$unit" >/dev/null 2>&1 || { err "Failed to disable $unit"; failed=1; }
    done
    
    # Disable and stop the unattended-upgrades service completely
    systemctl disable --now unattended-upgrades.service >/dev/null 2>&1 || { err "Failed to disable unattended-upgrades.service"; failed=1; }

    cat > "$APT_CFG" <<EOF
APT::Periodic::Update-Package-Lists "0";
APT::Periodic::Download-Upgradeable-Packages "0";
APT::Periodic::Unattended-Upgrade "0";
EOF

    if command -v snap >/dev/null 2>&1; then
        info "Holding Snap updates"
        snap set system refresh.hold="$SNAP_HOLD_DATE" >/dev/null 2>&1 || true
    fi

    [[ $failed -eq 0 ]] && ok "System updates DISABLED" || { err "System updates disabled with errors"; return 1; }
}

show_status() {
    # Ensure no extra arguments are passed to status
    if [[ -n "${1:-}" ]]; then
        err "Status command does not accept extra options: '$1'"
        usage
    fi

    last_trigger() {
        local ts
        ts=$(systemctl show "$1" --property=LastTriggerUSec 2>/dev/null | cut -d= -f2)
        [[ -n "$ts" && "$ts" != "n/a" ]] && echo " (last: $ts)" || echo ""
    }

    show_unit() {
        local name="$1"
        
        # Specific check for the upgrade service
        if [[ "$name" == "unattended-upgrades.service" ]]; then
            if systemctl is-enabled "$name" >/dev/null 2>&1; then
                echo "[ OK ] $name (enabled for apt-timers)"
            else
                echo "[ OFF ] $name (disabled)"
            fi
            return
        fi

        # Standard check for timers
        if systemctl is-active "$name" >/dev/null 2>&1; then
            local trigger=""
            [[ "$name" == *.timer ]] && trigger=$(last_trigger "$name")
            echo "[ OK ] $name${trigger}"
        else
            local state
            state=$(systemctl is-enabled "$name" 2>/dev/null | head -1)
            echo "[ OFF ] $name (${state:-disabled})"
        fi
    }

    check_apt_cfg() {
        local expected="$1"
        if [[ -f "$APT_CFG" ]]; then
            grep -q "Unattended-Upgrade \"${expected}\"" "$APT_CFG" 2>/dev/null && echo "ok" || echo "mismatch"
        else
            echo "missing"
        fi
    }

    echo
    echo "========================================"
    echo "        AUTOUPDATES STATUS"
    echo "========================================"
    echo

    for unit in "${APT_TIMERS[@]}" unattended-upgrades.service; do
        show_unit "$unit"
    done

    if systemctl is-active apt-daily.timer >/dev/null 2>&1; then
        cfg_state=$(check_apt_cfg "1")
    else
        cfg_state=$(check_apt_cfg "0")
    fi
    [[ "$cfg_state" == "mismatch" ]] && echo "[WARN] $APT_CFG does not match timer state"
    [[ "$cfg_state" == "missing"  ]] && echo "[WARN] $APT_CFG is missing"

    echo

    if command -v snap >/dev/null 2>&1; then
        if [[ $EUID -eq 0 ]]; then
            local hold
            hold=$(snap get system refresh.hold 2>/dev/null || true)
            if [[ -n "$hold" ]]; then
                echo "[HELD] snap refresh until $hold"
            else
                echo "[ OK ] snap updates enabled"
            fi
        else
            echo "[ -- ] snap (run as root to see hold status)"
        fi
    else
        echo "[ -- ] snap (not installed)"
    fi

    echo
}

# Main command dispatcher with strict arguments verification
main() {
    local cmd="${1:-}"

    case "$cmd" in
        enable|on)
            require_root
            enable_updates "${2:-}"
            show_status
            ;;
        disable|off)
            require_root
            disable_updates "${2:-}"
            show_status
            ;;
        status)
            show_status "${2:-}"
            ;;
            
        # If any third-party argument or typo is passed as a command
        *)
            if [[ -n "$cmd" ]]; then
                err "Unknown command: '$cmd'"
            fi
            usage
            ;;
    esac
}

main "$@"
